<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Students List</title>

  <style>
    :root{
      --bg:#0b1220;
      --card:#111a2e;
      --muted:#9fb0d0;
      --text:#e8eefc;
      --line:rgba(255,255,255,.08);
      --accent:#6ea8fe;
      --ok:#39d98a;
      --warn:#ffb020;
      --danger:#ff5c77;
    }
    *{box-sizing:border-box}
    body{
      margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background: radial-gradient(1200px 600px at 10% 0%, rgba(110,168,254,.25), transparent 60%),
                  radial-gradient(1200px 600px at 90% 20%, rgba(57,217,138,.18), transparent 55%),
                  var(--bg);
      color:var(--text);
    }
    a{color:var(--accent); text-decoration:none}
    a:hover{text-decoration:underline}
    .container{max-width:1100px; margin:40px auto; padding:0 16px}
    .header{
      display:flex; gap:16px; justify-content:space-between; align-items:flex-end; flex-wrap:wrap;
      margin-bottom:18px;
    }
    .title h1{margin:0; font-size:28px; letter-spacing:.2px}
    .title p{margin:6px 0 0; color:var(--muted); font-size:14px}
    .pill{
      display:inline-flex; align-items:center; gap:8px; padding:8px 12px;
      border:1px solid var(--line); border-radius:999px; background:rgba(255,255,255,.04);
      color:var(--muted); font-size:13px;
    }
    .card{
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      border:1px solid var(--line);
      border-radius:16px;
      overflow:hidden;
      box-shadow: 0 16px 40px rgba(0,0,0,.35);
    }
    .card-header{
      padding:14px 16px;
      display:flex; gap:12px; justify-content:space-between; align-items:center; flex-wrap:wrap;
      border-bottom:1px solid var(--line);
      background:rgba(0,0,0,.18);
    }
    .actions{display:flex; gap:10px; flex-wrap:wrap}
    .btn{
      display:inline-flex; align-items:center; gap:8px;
      padding:8px 12px; border-radius:10px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      color:var(--text);
      font-size:13px;
    }
    .btn:hover{background:rgba(255,255,255,.07); text-decoration:none}
    .table-wrap{overflow:auto}
    table{width:100%; border-collapse:collapse; min-width:860px}
    th, td{padding:12px 12px; border-bottom:1px solid var(--line); vertical-align:top}
    th{
      text-align:left; font-size:12px; letter-spacing:.6px; text-transform:uppercase; color:var(--muted);
      background:rgba(0,0,0,.12);
      position:sticky; top:0;
    }
    tr:hover td{background:rgba(255,255,255,.03)}
    .muted{color:var(--muted)}
    .badge{
      display:inline-flex; align-items:center;
      padding:4px 10px; border-radius:999px; font-size:12px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
    }
    .badge.ok{border-color:rgba(57,217,138,.35); color:var(--ok); background:rgba(57,217,138,.08)}
    .badge.warn{border-color:rgba(255,176,32,.35); color:var(--warn); background:rgba(255,176,32,.08)}
    .badge.danger{border-color:rgba(255,92,119,.35); color:var(--danger); background:rgba(255,92,119,.08)}
    .footer{
      margin-top:16px; color:var(--muted); font-size:13px;
      display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;
    }
    code.inline{
      padding:2px 6px; border-radius:8px; border:1px solid var(--line);
      background:rgba(0,0,0,.18); color:var(--text);
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="header">
      <div class="title">
        <h1>Students</h1>
        <p>Server-side page (EJS) — rendered from <code class="inline">GET /students/view</code></p>
      </div>

      <div class="pill">
        Total: <strong><%= Array.isArray(students) ? students.length : 0 %></strong> records
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="muted">
          Tip: If you see blank names, check field mapping in the template.
        </div>
        <div class="actions">
          <a class="btn" href="/students">🔗 Try API: /students</a>
          <a class="btn" href="/students/1">🔗 Try API: /students/1</a>
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Student No</th>
              <th>Name (TH)</th>
              <th>Program</th>
              <th>Status</th>
              <th>Contact</th>
            </tr>
          </thead>

          <tbody>
            <% if (!students || students.length === 0) { %>
              <tr>
                <td colspan="6" class="muted">No students found.</td>
              </tr>
            <% } else { %>

              <% students.forEach(s => { %>
                <tr>
                  <td>
                    <strong><%= s.student_id ?? '-' %></strong>
                  </td>

                  <td>
                    <%= s.student_no ?? '-' %>
                  </td>

                  <td>
                    <div><strong><%= (s.first_name_th ?? '-') %> <%= (s.last_name_th ?? '') %></strong></div>
                    <div class="muted" style="margin-top:4px">
                      EN: <%= (s.first_name_en ?? '-') %> <%= (s.last_name_en ?? '') %>
                    </div>
                  </td>

                  <td>
                    <div><span class="muted">program_id:</span> <strong><%= s.program_id ?? '-' %></strong></div>
                  </td>

                  <td>
                    <% const st = (s.status ?? '').toLowerCase(); %>
                    <% if (st === 'active') { %>
                      <span class="badge ok">active</span>
                    <% } else if (st === 'inactive') { %>
                      <span class="badge warn">inactive</span>
                    <% } else if (st) { %>
                      <span class="badge"><%= s.status %></span>
                    <% } else { %>
                      <span class="badge danger">null</span>
                    <% } %>
                  </td>

                  <td>
                    <div><span class="muted">email:</span> <%= s.email ?? '-' %></div>
                    <div style="margin-top:4px"><span class="muted">phone:</span> <%= s.phone ?? '-' %></div>
                  </td>
                </tr>
              <% }) %>

            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="footer">
      <div>Base URL: <code class="inline">http://localhost:3000</code></div>
      <div class="muted">Last render: <%= new Date().toLocaleString() %></div>
    </div>
  </div>
</body>
</html>
